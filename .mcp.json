{
  "mcpServers": {
    "terraform": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-v", "/c/Users/NKECHI/Ultimate-Agentic-DevOps-with-Claude-Code/terraform:/workspace",
        "-w", "/workspace",
        "hashicorp/terraform-mcp-server"
      ]
    },
    "aws": {
      "command": "uvx",
      "args": ["awslabs.aws-api-mcp-server@latest"],
      "env": {
        "AWS_PROFILE": "default",
        "AWS_REGION": "eu-north-1"
      }
    }
  }
}
